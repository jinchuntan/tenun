# ─────────────────────────────────────────────────────────────────────────────
# AI providers (server-side only — never exposed to the browser)
#
# OpenRouter is the PRIMARY provider for all AI features (job search, job detail,
# resume parsing). Groq is the automatic FALLBACK used when OpenRouter is missing,
# rate-limited, times out, or returns invalid JSON.
#
# You only need ONE of the two keys for the app to work. If both are set,
# OpenRouter is tried first and Groq is used only if OpenRouter fails.
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter — primary AI provider. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Tenun

# OpenRouter model selection (per route). These are OPTIONAL — if unset, the
# code default (openai/gpt-4o-mini) is used. gpt-4o-mini is cheap
# (~$0.000007/call) and works with OPENROUTER_DATA_COLLECTION=deny below.
#
# Want FREE models (qwen/nemotron :free)? They only route when you ALLOW prompt
# training — set OPENROUTER_DATA_COLLECTION=allow AND set the models below, e.g.
# nvidia/nemotron-3-super-120b-a12b:free. With "deny" they return HTTP 404.
# Not recommended for a CV app, since CV text is personal data.
# OPENROUTER_MODEL_JOB_INTENT=openai/gpt-4o-mini
# OPENROUTER_MODEL_JOB_DETAIL=openai/gpt-4o-mini
# OPENROUTER_MODEL_RESUME_PARSE=openai/gpt-4o-mini
# OPENROUTER_MODEL_SITE_GUIDE=openai/gpt-4o-mini
# OPENROUTER_MODEL_CV_GENERATE=openai/gpt-4o-mini
# OPENROUTER_MODEL_CV_ASSISTANT=openai/gpt-4o-mini
# OPENROUTER_MODEL_MOCK_INTERVIEW=openai/gpt-4o-mini  # AI Mock Interview feature

# OpenRouter provider policy — "deny" keeps your prompts out of training data.
OPENROUTER_DATA_COLLECTION=deny

# NOTE: All AI keys above are SERVER-SIDE ONLY. Never prefix them with
# NEXT_PUBLIC_. In Vercel, add them under Settings > Environment Variables >
# Production, then REDEPLOY (a refresh is not enough). Verify with
# GET /api/ai-health  and  GET /api/ai-health?test=true

# Groq — fallback AI provider. Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — required for Google sign-in and saving user sessions
# Create a project at https://supabase.com then go to Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Add callback URL in Supabase: Authentication > URL Configuration > Redirect URLs
# Add: http://localhost:3000/auth/callback (and your production URL when deploying)
# Enable Google provider: Authentication > Providers > Google
# Paste in your Google Console OAuth 2.0 Client ID and Secret

# Tenun Guide — public support email the mascot redirects to when it isn't sure.
# Exposed to the browser (NEXT_PUBLIC_); if left blank the UI falls back to a
# safe placeholder (support@tenun.example). Set this to your real support inbox.
NEXT_PUBLIC_TENUN_SUPPORT_EMAIL=
