# ─────────────────────────────────────────────────────────────────────────────
# AI providers (server-side only — never exposed to the browser)
#
# OpenRouter is the PRIMARY provider for all AI features (job search, job detail,
# resume parsing). Groq is the automatic FALLBACK used when OpenRouter is missing,
# rate-limited, times out, or returns invalid JSON.
#
# You only need ONE of the two keys for the app to work. If both are set,
# OpenRouter is tried first and Groq is used only if OpenRouter fails.
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter — primary AI provider. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Tenun

# OpenRouter model selection (per route). The default below is free, has a large
# context window, and supports response_format JSON output.
OPENROUTER_MODEL_JOB_INTENT=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL_JOB_DETAIL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODEL_RESUME_PARSE=qwen/qwen3-next-80b-a3b-instruct:free

# OpenRouter provider policy — "deny" keeps your prompts out of training data.
OPENROUTER_DATA_COLLECTION=deny

# Groq — fallback AI provider. Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase — required for Google sign-in and saving user sessions
# Create a project at https://supabase.com then go to Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Add callback URL in Supabase: Authentication > URL Configuration > Redirect URLs
# Add: http://localhost:3000/auth/callback (and your production URL when deploying)
# Enable Google provider: Authentication > Providers > Google
# Paste in your Google Console OAuth 2.0 Client ID and Secret
